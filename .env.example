# Copy to code/.env and fill in. NEVER commit code/.env (it is gitignored).
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

PERCEPTION_PROVIDER=gemini       # gemini | claude | mock
PERCEPTION_MODEL=gemini-2.5-flash-lite
JUDGE_PROVIDER=claude            # claude | gemini | mock
JUDGE_MODEL=claude-sonnet-4-6
MAX_CONCURRENCY=4
